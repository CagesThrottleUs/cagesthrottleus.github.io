#!/bin/sh

set -e

echo ""
echo "=== Pre-push gate ==="
echo ""

echo ""
echo "[1/5] Type checking..."
npm run type:check

echo "[2/5] Checking formatting..."
npm run format:check

echo ""
echo "[3/5] Running linter..."
npm run lint

echo ""
echo "[4/5] Running unit + integration tests..."
npm run test:all

echo ""
echo "[5/6] Building..."
npm run build

echo ""
echo "[6/6] Lighthouse audit (performance / a11y / best-practices / SEO)..."
echo "      Requires Chrome. Set CHROME_PATH to override the detected binary."
npm run lighthouse:ci

echo ""
echo "All checks passed. Pushing."
echo ""
